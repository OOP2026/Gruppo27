<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.GestioneAnagraficaPazienti">
  <grid id="27dc6" binding="mainPanel" layout-manager="GridLayoutManager" row-count="4" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="10" vgap="10">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="600" height="500"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      
      <grid id="formGrid" layout-manager="GridLayoutManager" row-count="4" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="10" vgap="5">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="etched" title="Dati Paziente"/>
        <children>
          <component id="lblCf" class="javax.swing.JLabel">
            <constraints><grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints>
            <properties><text value="SSN:"/></properties>
          </component>
          <component id="txtCf" class="javax.swing.JTextField" binding="txtCf">
            <constraints><grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints>
            <properties/>
          </component>
          <component id="lblNome" class="javax.swing.JLabel">
            <constraints><grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints>
            <properties><text value="Nome:"/></properties>
          </component>
          <component id="txtNome" class="javax.swing.JTextField" binding="txtNome">
            <constraints><grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints>
            <properties/>
          </component>
          <component id="lblCognome" class="javax.swing.JLabel">
            <constraints><grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints>
            <properties><text value="Cognome:"/></properties>
          </component>
          <component id="txtCognome" class="javax.swing.JTextField" binding="txtCognome">
            <constraints><grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints>
            <properties/>
          </component>
          <component id="lblRecapito" class="javax.swing.JLabel">
            <constraints><grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/></constraints>
            <properties><text value="Recapito:"/></properties>
          </component>
          <component id="txtRecapito" class="javax.swing.JTextField" binding="txtRecapito">
            <constraints><grid row="3" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/></constraints>
            <properties/>
          </component>
        </children>
      </grid>

      <grid id="btnGrid" layout-manager="GridLayoutManager" row-count="1" column-count="4" same-size-horizontally="false" same-size-vertically="false" hgap="5" vgap="0">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="btnAggiungi" class="javax.swing.JButton" binding="btnAggiungi">
            <constraints><grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/></constraints>
            <properties><text value="Aggiungi"/></properties>
          </component>
          <component id="btnModifica" class="javax.swing.JButton" binding="btnModifica">
            <constraints><grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/></constraints>
            <properties><text value="Modifica"/></properties>
          </component>
          <component id="btnElimina" class="javax.swing.JButton" binding="btnElimina">
            <constraints><grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/></constraints>
            <properties><text value="Elimina"/></properties>
          </component>
          <component id="btnPulisci" class="javax.swing.JButton" binding="btnPulisci">
            <constraints><grid row="0" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/></constraints>
            <properties><text value="Pulisci Campi"/></properties>
          </component>
        </children>
      </grid>

      <grid id="searchGrid" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="5" vgap="0">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <hspacer id="searchSpacer">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
          </hspacer>
          <component id="txtRicerca" class="javax.swing.JTextField" binding="txtRicerca">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="200" height="-1"/>
              </grid>
            </constraints>
            <properties>
              <toolTipText value="Cerca per SSN, Nome, Cognome o Recapito"/>
            </properties>
          </component>
          <component id="btnCerca" class="javax.swing.JButton" binding="btnCerca">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="🔍 Cerca"/>
            </properties>
          </component>
        </children>
      </grid>

      <scrollpane id="scrollTable">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="etched" title="Elenco Pazienti"/>
        <children>
          <component id="tablePazienti" class="javax.swing.JTable" binding="tablePazienti">
            <constraints/>
            <properties/>
          </component>
        </children>
      </scrollpane>
    </children>
  </grid>
</form>